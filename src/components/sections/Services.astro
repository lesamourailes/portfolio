---
import { services } from '../../data/content';
import { ui, t } from '../../i18n/ui';
import type { Locale } from '../../data/content';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const base = locale === 'en' ? '/en' : '';
---
<section class="section" id="services">
  <div class="container">
    <div class="reveal">
      <span class="eyebrow">{t(ui.services.eyebrow, locale)}</span>
      <h2 class="section-title">{t(ui.services.heading, locale)}</h2>
    </div>

    <div class="services">
      {services.map((s) => (
        <article class="svc-card reveal">
          <h3 class="svc-card__title">{t(s.title, locale)}</h3>
          <p class="svc-card__promise">{t(s.promise, locale)}</p>

          <div class="svc-card__group">
            <span class="svc-card__label">{t(ui.services.fit, locale)}</span>
            <p class="svc-card__fit">{t(s.fit, locale)}</p>
          </div>

          <div class="svc-card__group">
            <span class="svc-card__label">{t(ui.services.does, locale)}</span>
            <ul class="svc-card__does">
              {s.does.map((d) => <li>{t(d, locale)}</li>)}
            </ul>
          </div>

          <p class="svc-card__anchor">{t(s.anchor, locale)}</p>

          <a class="svc-card__cta" href={`${base}/#contact`}>
            {t(ui.services.discuss, locale)}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services { margin-top: 48px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .svc-card {
    display: flex; flex-direction: column;
    background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
    padding: 32px 30px; transition: border-color 0.25s ease, transform 0.25s ease;
  }
  .svc-card:hover { border-color: var(--border-strong); transform: translateY(-3px); }
  .svc-card__title { font-size: 21px; letter-spacing: -0.01em; }
  .svc-card__promise { margin-top: 10px; font-size: 16px; font-weight: 600; line-height: 1.4; }

  .svc-card__group { margin-top: 22px; }
  .svc-card__label { font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); }
  .svc-card__fit { margin-top: 6px; color: var(--text-muted); font-size: 15px; line-height: 1.5; }
  .svc-card__does { margin: 10px 0 0; padding: 0; list-style: none; display: grid; gap: 9px; }
  .svc-card__does li { position: relative; padding-left: 20px; font-size: 14px; color: var(--text-muted); line-height: 1.45; }
  .svc-card__does li::before { content: ''; position: absolute; left: 2px; top: 8px; width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }

  .svc-card__anchor {
    margin-top: 24px; padding: 12px 16px;
    background: var(--accent-soft); border-left: 2px solid var(--accent); border-radius: 0 8px 8px 0;
    font-size: 13px; line-height: 1.5; color: var(--text);
  }
  .svc-card__cta {
    margin-top: auto; padding-top: 22px;
    display: inline-flex; align-items: center; gap: 6px;
    font-weight: 600; font-size: 15px; color: var(--accent);
  }
  .svc-card__cta svg { transition: transform 0.2s ease; }
  .svc-card__cta:hover svg { transform: translateX(3px); }

  @media (max-width: 900px) { .services { grid-template-columns: 1fr; } }
</style>
