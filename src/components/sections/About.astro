---
import { about, education } from '../../data/content';
import { ui, t } from '../../i18n/ui';
import type { Locale } from '../../data/content';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const intro = about[locale];
---
<section class="section" id="about">
  <div class="container about">
    <div class="about__intro reveal">
      <span class="eyebrow">{t(ui.sections.about, locale)}</span>
      {intro.paragraphs.map((p) => <p class="about__p">{p}</p>)}
      {intro.bullets.length > 0 && (
        <ul class="about__list">
          {intro.bullets.map((b) => <li>{b}</li>)}
        </ul>
      )}
    </div>

    <aside class="about__edu reveal">
      <h3 class="about__edu-title">{t(ui.sections.education, locale)}</h3>
      <ul>
        {education.map((e) => (
          <li>
            <span class="about__edu-period">{e.period}</span>
            <span class="about__edu-school">{t(e.school, locale)}</span>
            <span class="about__edu-degree">{t(e.degree, locale)}</span>
          </li>
        ))}
      </ul>
    </aside>
  </div>
</section>

<style>
  .about { display: grid; grid-template-columns: 1.6fr 1fr; gap: 56px; align-items: start; }
  .about__p { font-size: 20px; line-height: 1.6; margin-top: 20px; }
  .about__p:first-of-type { margin-top: 0; }
  .about__list { margin: 20px 0 0; padding: 0; list-style: none; display: grid; gap: 12px; }
  .about__list li { position: relative; padding-left: 26px; font-size: 18px; line-height: 1.5; }
  .about__list li::before { content: ''; position: absolute; left: 4px; top: 10px; width: 8px; height: 8px; border-radius: 50%; background: var(--accent); }

  .about__edu { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 28px; }
  .about__edu-title { font-size: 18px; margin-bottom: 20px; }
  .about__edu ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 22px; }
  .about__edu li { display: flex; flex-direction: column; gap: 3px; padding-left: 16px; border-left: 2px solid var(--accent); }
  .about__edu-period { font-size: 13px; font-weight: 600; color: var(--accent); }
  .about__edu-school { font-weight: 600; }
  .about__edu-degree { font-size: 14px; color: var(--text-muted); }

  @media (max-width: 900px) { .about { grid-template-columns: 1fr; gap: 36px; } .about__p { font-size: 18px; } }
</style>
