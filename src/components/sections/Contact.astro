---
import { contacts } from '../../data/content';
import { ui, t } from '../../i18n/ui';
import type { Locale } from '../../data/content';
interface Props { locale: Locale; }
const { locale } = Astro.props;

const icons = {
  mail: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-10 6L2 7"></path></svg>',
  telegram: '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M21.94 4.66a1.2 1.2 0 0 0-1.24-.2L3.3 11.2c-.86.34-.83 1.58.05 1.87l4.34 1.44 1.64 5.02c.2.6.97.77 1.42.32l2.4-2.36 4.32 3.18c.5.37 1.22.1 1.36-.5l3.2-14.4a1.2 1.2 0 0 0-.09-.83ZM9.9 14.3l8.02-5.05c.16-.1.33.12.19.25l-6.5 6.04c-.2.18-.32.43-.36.7l-.22 1.6-1.13-3.28a.5.5 0 0 1 .01-.26Z"></path></svg>',
  linkedin: '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M6.94 5a2 2 0 1 1-4 0 2 2 0 0 1 4 0ZM3.25 8.5h3.4V21h-3.4V8.5Zm5.5 0h3.26v1.71h.05c.45-.86 1.56-1.77 3.21-1.77 3.43 0 4.07 2.26 4.07 5.2V21h-3.4v-5.46c0-1.3-.02-2.98-1.82-2.98-1.82 0-2.1 1.42-2.1 2.89V21h-3.4V8.5Z"></path></svg>',
  mentor: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10 12 5 2 10l10 5 10-5Z"></path><path d="M6 12v5c3 2.5 9 2.5 12 0v-5"></path></svg>',
};

const items = [
  { label: 'Email', value: contacts.email, href: `mailto:${contacts.email}`, icon: icons.mail },
  { label: 'Telegram', value: contacts.telegram.handle, href: contacts.telegram.url, icon: icons.telegram },
  { label: 'LinkedIn', value: '/in/artur-markarian', href: contacts.linkedin, icon: icons.linkedin },
  { label: 'GetMentor', value: 'getmentor.dev', href: contacts.getmentor, icon: icons.mentor },
];
---
<section class="section" id="contact">
  <div class="container">
    <div class="contact reveal">
      <div class="contact__lead">
        <span class="eyebrow">{t(ui.sections.contact, locale)}</span>
        <h2 class="contact__title">{locale === 'ru' ? 'Давайте поговорим' : 'Let’s talk'}</h2>
        <p class="contact__text">{t(ui.contact.lead, locale)}</p>
        <a class="btn btn--primary contact__mailbtn" href={`mailto:${contacts.email}`}>{locale === 'ru' ? 'Написать на почту' : 'Send an email'}</a>
      </div>

      <div class="contact__grid">
        {items.map((it) => (
          <a class="contact__item" href={it.href} title={it.value} target={it.href.startsWith('mailto') ? undefined : '_blank'} rel="noopener">
            <span class="contact__icon" set:html={it.icon} aria-hidden="true"></span>
            <span class="contact__label">{it.label}</span>
            <svg class="contact__go" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10"></path></svg>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center;
    background: var(--surface); border: 1px solid var(--border); border-radius: 24px; padding: 56px;
  }
  .contact__title { font-size: clamp(32px, 4.5vw, 52px); letter-spacing: -0.03em; margin: 8px 0 16px; }
  .contact__text { color: var(--text-muted); font-size: 18px; max-width: 40ch; }
  .contact__mailbtn { margin-top: 28px; }

  .contact__grid { display: flex; flex-direction: column; gap: 12px; }
  .contact__item {
    display: flex; align-items: center; gap: 16px;
    background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius);
    padding: 16px 18px; transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .contact__item:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: var(--shadow); }
  .contact__icon {
    flex: none; display: inline-flex; align-items: center; justify-content: center;
    width: 44px; height: 44px; border-radius: 12px;
    background: var(--accent-soft); color: var(--accent);
  }
  .contact__label { font-size: 16px; font-weight: 600; color: var(--text); }
  .contact__go { flex: none; margin-left: auto; color: var(--text-muted); transition: color 0.2s ease, transform 0.2s ease; }
  .contact__item:hover .contact__go { color: var(--accent); transform: translate(2px, -2px); }

  @media (max-width: 820px) {
    .contact { grid-template-columns: 1fr; gap: 32px; padding: 36px; }
  }
  @media (max-width: 380px) { .contact { padding: 24px; } }
</style>
