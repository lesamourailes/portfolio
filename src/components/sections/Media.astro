---
import { media } from '../../data/content';
import { ui, t, byYearDesc } from '../../i18n/ui';
import type { Locale } from '../../data/content';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const items = byYearDesc(media, (m) => m.year);
---
<section class="section" id="media">
  <div class="container">
    <div class="reveal">
      <span class="eyebrow">{t(ui.sections.media, locale)}</span>
      <h2 class="section-title">{locale === 'ru' ? 'СМИ и выступления' : 'Media & talks'}</h2>
    </div>

    <div class="media">
      {items.map((m) => (
        <a class="media-card reveal" href={m.url} target="_blank" rel="noopener">
          <div class="media-card__top">
            <span class={`media-card__kind media-card__kind--${m.kind}`}>{t(ui.media_kind[m.kind], locale)}</span>
            <svg class="media-card__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 17 17 7M7 7h10v10"></path>
            </svg>
          </div>
          <h3 class="media-card__title">{t(m.title, locale)}</h3>
          <div class="media-card__foot">
            <span class="media-card__source">{m.source}</span>
            {m.year && <span class="media-card__year">{m.year}</span>}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .media { margin-top: 44px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .media-card {
    display: flex; flex-direction: column; gap: 16px;
    background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
    padding: 24px; min-height: 190px;
    transition: border-color 0.25s ease, transform 0.25s ease;
  }
  .media-card:hover { border-color: var(--accent); transform: translateY(-3px); }
  .media-card__top { display: flex; align-items: center; justify-content: space-between; }
  .media-card__kind { font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 4px 10px; border-radius: 999px; }
  .media-card__kind--press { background: var(--blue-soft); color: var(--blue); }
  .media-card__kind--speaking { background: var(--accent-soft); color: var(--accent); }
  .media-card__kind--profile { background: var(--surface-2); color: var(--text-muted); }
  .media-card__arrow { color: var(--text-muted); transition: color 0.2s ease, transform 0.2s ease; }
  .media-card:hover .media-card__arrow { color: var(--accent); transform: translate(2px, -2px); }
  .media-card__title { font-size: 17px; font-weight: 600; letter-spacing: -0.01em; line-height: 1.35; flex: 1; }
  .media-card__foot { display: flex; align-items: center; gap: 10px; font-size: 14px; }
  .media-card__source { font-weight: 600; }
  .media-card__year { color: var(--text-muted); }
  .media-card__year::before { content: '·'; margin-right: 10px; color: var(--text-muted); }

  @media (max-width: 900px) { .media { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .media { grid-template-columns: 1fr; } .media-card { min-height: 0; } }
</style>
