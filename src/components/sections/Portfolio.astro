---
import { portfolio } from '../../data/content';
import { ui, t } from '../../i18n/ui';
import type { Locale } from '../../data/content';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const hasItems = portfolio.length > 0;
---
<section class="section" id="portfolio">
  <div class="container">
    <div class="reveal">
      <span class="eyebrow">{t(ui.sections.portfolio, locale)}</span>
      <h2 class="section-title">{locale === 'ru' ? 'Продукты в деталях' : 'Products in detail'}</h2>
    </div>

    {hasItems ? (
      <div class="portfolio">
        {portfolio.map((item) => (
          <article class="pf-card reveal">
            <div class="pf-card__media"><img src={item.src} alt={t(item.title, locale)} loading="lazy" /></div>
            <div class="pf-card__body">
              <h3>{t(item.title, locale)}</h3>
              <p>{t(item.description, locale)}</p>
              {item.tags && <div class="pf-card__tags">{item.tags.map((tg) => <span class="tag">{tg}</span>)}</div>}
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="portfolio__empty reveal">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2"></rect>
          <circle cx="9" cy="9" r="2"></circle>
          <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
        </svg>
        <p>{t(ui.portfolio.empty, locale)}</p>
      </div>
    )}
  </div>
</section>

<style>
  .portfolio { margin-top: 44px; display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
  .pf-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; transition: border-color 0.25s ease; }
  .pf-card:hover { border-color: var(--border-strong); }
  .pf-card__media { aspect-ratio: 16 / 10; overflow: hidden; background: var(--surface-2); }
  .pf-card__media img { width: 100%; height: 100%; object-fit: cover; }
  .pf-card__body { padding: 24px; }
  .pf-card__body h3 { font-size: 20px; }
  .pf-card__body p { margin-top: 8px; color: var(--text-muted); }
  .pf-card__tags { margin-top: 16px; display: flex; flex-wrap: wrap; gap: 8px; }

  .portfolio__empty {
    margin-top: 40px; padding: 56px 32px; text-align: center;
    border: 1.5px dashed var(--border-strong); border-radius: var(--radius);
    color: var(--text-muted); display: flex; flex-direction: column; align-items: center; gap: 14px;
  }
  .portfolio__empty p { max-width: 42ch; }

  @media (max-width: 780px) { .portfolio { grid-template-columns: 1fr; } }
</style>
