---
import { portfolio } from '../../data/content';
import { ui, t } from '../../i18n/ui';
import type { Locale } from '../../data/content';
interface Props { locale: Locale; }
const { locale } = Astro.props;

const groups = [
  { variant: 'web', title: ui.portfolio.web, items: portfolio.web },
  { variant: 'mobile', title: ui.portfolio.mobile, items: portfolio.mobile },
] as const;
---
<section class="section" id="portfolio">
  <div class="container">
    <div class="reveal">
      <span class="eyebrow">{t(ui.sections.portfolio, locale)}</span>
      <h2 class="section-title">{locale === 'ru' ? 'Мои продукты' : 'My products'}</h2>
    </div>

    {groups.map((g) => (
      <div class="pf-group reveal">
        <h3 class="pf-group__title">{t(g.title, locale)}</h3>

        {g.items.length > 0 ? (
          <div class={`pf-grid pf-grid--${g.variant}`}>
            {g.items.map((item) => {
              const full = locale === 'en' && item.srcEn ? item.srcEn : item.src;
              const thumb = locale === 'en'
                ? (item.previewEn ?? item.preview ?? item.srcEn ?? item.src)
                : (item.preview ?? item.src);
              return (
                <article class="pf-card">
                  <button class={`pf-card__media pf-card__media--${g.variant}`} type="button" data-full={full} data-title={t(item.title, locale)} aria-label={t(item.title, locale)}>
                    <img src={thumb} alt={t(item.title, locale)} loading="lazy" />
                  </button>
                  <div class="pf-card__body">
                    <h4>{t(item.title, locale)}</h4>
                    <p class="pf-card__desc">{t(item.description, locale)}</p>
                    {item.bullets && (
                      <ul class="pf-card__bullets">
                        {item.bullets.map((b) => <li>{t(b, locale)}</li>)}
                      </ul>
                    )}
                    {item.result && (
                      <p class="pf-card__result"><span>{locale === 'ru' ? 'Результат' : 'Result'}</span>{t(item.result, locale)}</p>
                    )}
                    {item.tags && <div class="pf-card__tags">{item.tags.map((tg) => <span class="tag">{tg}</span>)}</div>}
                  </div>
                </article>
              );
            })}
          </div>
        ) : (
          <div class="portfolio__empty">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2"></rect>
              <circle cx="9" cy="9" r="2"></circle>
              <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
            </svg>
            <p>{t(ui.portfolio.empty, locale)}</p>
          </div>
        )}
      </div>
    ))}
  </div>

  <div class="lightbox" id="portfolio-lightbox" aria-hidden="true" role="dialog" aria-modal="true">
    <button class="lightbox__close" data-lb="close" aria-label="Close">&times;</button>
    <button class="lightbox__nav lightbox__nav--prev" data-lb="prev" aria-label="Previous"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg></button>
    <figure class="lightbox__figure">
      <img id="portfolio-lightbox-img" src="" alt="" />
      <figcaption id="portfolio-lightbox-caption"></figcaption>
    </figure>
    <button class="lightbox__nav lightbox__nav--next" data-lb="next" aria-label="Next"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></button>
  </div>
</section>

<script>
  const lb = document.getElementById('portfolio-lightbox');
  const lbImg = document.getElementById('portfolio-lightbox-img');
  const lbCaption = document.getElementById('portfolio-lightbox-caption');
  const triggers = [...document.querySelectorAll('#portfolio .pf-card__media')];
  const slides = triggers.map((b) => ({ full: b.dataset.full, title: b.dataset.title }));
  let current = 0;

  function show(i) {
    current = (i + slides.length) % slides.length;
    lbImg.src = slides[current].full;
    lbImg.alt = slides[current].title || '';
    lbCaption.textContent = slides[current].title || '';
    lb.classList.add('is-open');
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function close() {
    lb.classList.remove('is-open');
    lb.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  triggers.forEach((b, i) => b.addEventListener('click', () => show(i)));
  lb?.addEventListener('click', (e) => {
    const el = e.target.closest('[data-lb]');
    const action = el?.dataset.lb;
    if (action === 'close' || e.target === lb) close();
    else if (action === 'prev') show(current - 1);
    else if (action === 'next') show(current + 1);
  });
  document.addEventListener('keydown', (e) => {
    if (!lb.classList.contains('is-open')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') show(current - 1);
    if (e.key === 'ArrowRight') show(current + 1);
  });
</script>

<style>
  .pf-group { margin-top: 44px; }
  .pf-group__title { font-size: 20px; margin-bottom: 20px; }

  .pf-grid { display: grid; gap: 24px; }
  .pf-grid--web { grid-template-columns: repeat(2, 1fr); }
  .pf-grid--mobile { grid-template-columns: repeat(4, 1fr); }

  .pf-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; transition: border-color 0.25s ease; }
  .pf-card:hover { border-color: var(--border-strong); }
  .pf-card__media {
    display: block; width: 100%; margin: 0; padding: 0; border: 0; font: inherit; color: inherit;
    overflow: hidden; background: var(--surface-2); cursor: pointer;
    border-bottom: 1px solid var(--border);
  }
  .pf-card__media--web { aspect-ratio: 16 / 10; padding: 12px; }
  .pf-card__media--mobile { aspect-ratio: 1; }
  .pf-card__media img { width: 100%; height: 100%; object-fit: cover; object-position: top; transition: transform 0.3s ease; }
  .pf-card__media--web img { object-fit: contain; }
  .pf-card__media:hover img { transform: scale(1.03); }
  .pf-card__body { padding: 22px 24px 24px; }
  .pf-card__body h4 { font-size: 19px; letter-spacing: -0.01em; }
  .pf-card__desc { margin-top: 6px; color: var(--text-muted); font-size: 15px; }
  .pf-card__bullets { margin: 16px 0 0; padding: 0; list-style: none; display: grid; gap: 9px; }
  .pf-card__bullets li { position: relative; padding-left: 20px; font-size: 14px; color: var(--text-muted); line-height: 1.45; }
  .pf-card__bullets li::before { content: ''; position: absolute; left: 2px; top: 8px; width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }
  .pf-card__result { margin-top: 16px; font-size: 14px; font-weight: 600; display: flex; flex-wrap: wrap; gap: 8px; align-items: baseline; }
  .pf-card__result span { font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--accent); background: var(--accent-soft); padding: 3px 9px; border-radius: 999px; }
  .pf-card__tags { margin-top: 14px; display: flex; flex-wrap: wrap; gap: 8px; }

  .portfolio__empty {
    padding: 48px 32px; text-align: center;
    border: 1.5px dashed var(--border-strong); border-radius: var(--radius);
    color: var(--text-muted); display: flex; flex-direction: column; align-items: center; gap: 12px;
  }
  .portfolio__empty p { max-width: 42ch; }

  .lightbox {
    position: fixed; inset: 0; z-index: 100;
    display: none; align-items: center; justify-content: center;
    background: rgba(6, 6, 8, 0.9); backdrop-filter: blur(6px); padding: 40px;
  }
  .lightbox.is-open { display: flex; }
  .lightbox__figure { margin: 0; max-width: 90vw; max-height: 88vh; display: flex; flex-direction: column; align-items: center; gap: 14px; }
  .lightbox__figure img { max-width: 100%; max-height: 80vh; border-radius: 8px; box-shadow: 0 30px 80px rgba(0,0,0,0.5); }
  .lightbox__figure figcaption { color: #fff; font-size: 15px; text-align: center; opacity: 0.9; }
  .lightbox__close { position: absolute; top: 22px; right: 26px; background: none; border: none; color: #fff; font-size: 40px; line-height: 1; cursor: pointer; opacity: 0.8; }
  .lightbox__close:hover { opacity: 1; }
  .lightbox__nav {
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 52px; height: 52px; border-radius: 50%;
    background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: #fff;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: background 0.2s ease;
  }
  .lightbox__nav svg { pointer-events: none; }
  .lightbox__nav:hover { background: rgba(255,255,255,0.22); }
  .lightbox__nav--prev { left: 24px; }
  .lightbox__nav--next { right: 24px; }

  @media (max-width: 780px) {
    .pf-grid--web { grid-template-columns: 1fr; }
    .pf-grid--mobile { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .lightbox { padding: 16px; }
    .lightbox__nav { width: 42px; height: 42px; }
    .lightbox__nav--prev { left: 8px; }
    .lightbox__nav--next { right: 8px; }
  }
</style>
