---
import { portfolio } from '../../data/content';
import { ui, t } from '../../i18n/ui';
import type { Locale } from '../../data/content';
interface Props { locale: Locale; }
const { locale } = Astro.props;

const groups = [
  { variant: 'web', title: ui.portfolio.web, items: portfolio.web },
  { variant: 'mobile', title: ui.portfolio.mobile, items: portfolio.mobile },
] as const;
---
<section class="section" id="portfolio">
  <div class="container">
    <div class="reveal">
      <span class="eyebrow">{t(ui.sections.portfolio, locale)}</span>
      <h2 class="section-title">{locale === 'ru' ? 'Мои продукты' : 'My products'}</h2>
    </div>

    {groups.map((g) => (
      <div class="pf-group reveal">
        <h3 class="pf-group__title">{t(g.title, locale)}</h3>

        {g.items.length > 0 ? (
          <div class={`pf-grid pf-grid--${g.variant}`}>
            {g.items.map((item) => (
              <article class="pf-card">
                <div class={`pf-card__media pf-card__media--${g.variant}`}>
                  <img src={item.src} alt={t(item.title, locale)} loading="lazy" />
                </div>
                <div class="pf-card__body">
                  <h4>{t(item.title, locale)}</h4>
                  <p>{t(item.description, locale)}</p>
                  {item.tags && <div class="pf-card__tags">{item.tags.map((tg) => <span class="tag">{tg}</span>)}</div>}
                </div>
              </article>
            ))}
          </div>
        ) : (
          <div class="portfolio__empty">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2"></rect>
              <circle cx="9" cy="9" r="2"></circle>
              <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
            </svg>
            <p>{t(ui.portfolio.empty, locale)}</p>
          </div>
        )}
      </div>
    ))}
  </div>
</section>

<style>
  .pf-group { margin-top: 44px; }
  .pf-group__title { font-size: 20px; margin-bottom: 20px; }

  .pf-grid { display: grid; gap: 24px; }
  .pf-grid--web { grid-template-columns: repeat(2, 1fr); }
  .pf-grid--mobile { grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); }

  .pf-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; transition: border-color 0.25s ease; }
  .pf-card:hover { border-color: var(--border-strong); }
  .pf-card__media { overflow: hidden; background: var(--surface-2); }
  .pf-card__media--web { aspect-ratio: 16 / 10; }
  .pf-card__media--mobile { aspect-ratio: 9 / 19; }
  .pf-card__media img { width: 100%; height: 100%; object-fit: cover; object-position: top; }
  .pf-card__body { padding: 20px 22px; }
  .pf-card__body h4 { font-size: 18px; letter-spacing: -0.01em; }
  .pf-card__body p { margin-top: 8px; color: var(--text-muted); font-size: 15px; }
  .pf-card__tags { margin-top: 14px; display: flex; flex-wrap: wrap; gap: 8px; }

  .portfolio__empty {
    padding: 48px 32px; text-align: center;
    border: 1.5px dashed var(--border-strong); border-radius: var(--radius);
    color: var(--text-muted); display: flex; flex-direction: column; align-items: center; gap: 12px;
  }
  .portfolio__empty p { max-width: 42ch; }

  @media (max-width: 780px) {
    .pf-grid--web { grid-template-columns: 1fr; }
    .pf-grid--mobile { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); }
  }
</style>
