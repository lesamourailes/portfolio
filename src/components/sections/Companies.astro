---
import { companies } from '../../data/content';
import { ui, t } from '../../i18n/ui';
import type { Locale } from '../../data/content';
interface Props { locale: Locale; }
const { locale } = Astro.props;
---
<section class="companies-strip reveal">
  <div class="container">
    <p class="companies-strip__label">{t(ui.companies, locale)}</p>
    <div class="companies-strip__row">
      {companies.map((c) => (
        <div class="companies-strip__chip"><img src={c.src} alt={c.name} loading="lazy" /></div>
      ))}
    </div>
  </div>
</section>

<style>
  .companies-strip { padding: 24px 0 8px; }
  .companies-strip__label {
    text-align: center; font-size: 13px; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted);
    margin-bottom: 22px;
  }
  .companies-strip__row { display: flex; flex-wrap: wrap; justify-content: center; gap: 16px; }
  .companies-strip__chip {
    display: flex; align-items: center; justify-content: center;
    width: 158px; height: 88px; padding: 16px 24px;
    background: #fff; border: 1px solid var(--border); border-radius: 14px;
    box-shadow: var(--shadow);
  }
  .companies-strip__chip img { max-width: 100%; max-height: 100%; object-fit: contain; }
  @media (max-width: 560px) {
    .companies-strip__chip { width: calc(50% - 8px); height: 76px; }
  }
</style>
