---
import { communities } from '../../data/content';
import { ui, t, byYearDesc } from '../../i18n/ui';
import type { Locale } from '../../data/content';
interface Props { locale: Locale; }
const { locale } = Astro.props;

const groups = [
  { key: 'pro', title: ui.communities.pro },
  { key: 'jury', title: ui.communities.jury },
].map((g) => ({
  ...g,
  items: byYearDesc(communities.filter((c) => c.group === g.key), (c) => c.period),
}));
---
<section class="section section--tight" id="communities">
  <div class="container">
    <div class="reveal">
      <span class="eyebrow">{t(ui.sections.communities, locale)}</span>
      <h2 class="section-title">{locale === 'ru' ? 'Членство в организациях' : 'Memberships'}</h2>
    </div>

    {groups.map((g) => (
      <div class="comm-group reveal">
        <h3 class="comm-group__title">{t(g.title, locale)}</h3>
        <div class="communities">
          {g.items.map((c) => (
            <article class="comm-card">
              <div class="comm-card__top">
                {c.period !== '—' ? <span class="comm-card__period">{c.period}</span> : <span />}
                <div class={`comm-card__logo${c.logoStyle ? ` comm-card__logo--${c.logoStyle}` : ''}`}>
                  <img src={c.logo} alt={t(c.title, locale)} loading="lazy" />
                </div>
              </div>
              <h4>{t(c.title, locale)}</h4>
              <p>{t(c.detail, locale)}</p>
            </article>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .comm-group { margin-top: 44px; }
  .comm-group__title { font-size: 20px; margin-bottom: 20px; }
  .communities { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
  .comm-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 28px; }
  .comm-card__top { display: flex; align-items: center; justify-content: space-between; gap: 16px; min-height: 40px; margin-bottom: 20px; }
  .comm-card__period { padding: 4px 12px; border-radius: 999px; background: var(--accent-soft); color: var(--accent); font-size: 13px; font-weight: 700; }
  .comm-card__logo { display: inline-flex; align-items: center; }
  /* Широкие вордмарки ограничиваем по ширине, иначе они перевешивают ряд оптически */
  .comm-card__logo img { height: 34px; width: auto; max-width: 116px; object-fit: contain; }
  /* Знак встроен в собственный фон — показываем плиткой, а не «вырезкой» */
  .comm-card__logo--tile img { height: 40px; border-radius: 8px; border: 1px solid var(--border); }
  /* Одноцветный тёмный знак: в тёмной теме выворачиваем, hue-rotate возвращает акцентный цвет */
  :global(html[data-theme='dark']) .comm-card__logo--invert img { filter: invert(1) hue-rotate(180deg); }
  .comm-card h4 { font-size: 19px; letter-spacing: -0.01em; }
  .comm-card p { margin-top: 8px; color: var(--text-muted); }
  @media (max-width: 780px) { .communities { grid-template-columns: 1fr; } }
</style>
