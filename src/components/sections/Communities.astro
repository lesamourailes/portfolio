---
import { communities } from '../../data/content';
import { ui, t, byYearDesc } from '../../i18n/ui';
import type { Locale } from '../../data/content';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const items = byYearDesc(communities, (c) => c.period);
---
<section class="section section--tight" id="communities">
  <div class="container">
    <div class="reveal">
      <span class="eyebrow">{t(ui.sections.communities, locale)}</span>
      <h2 class="section-title">{locale === 'ru' ? 'Членство в организациях' : 'Memberships'}</h2>
    </div>

    <div class="communities">
      {items.map((c) => (
        <article class="comm-card reveal">
          {c.period !== '—' && <span class="comm-card__period">{c.period}</span>}
          <h3>{t(c.title, locale)}</h3>
          <p>{t(c.detail, locale)}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .communities { margin-top: 44px; display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
  .comm-card { position: relative; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 28px; }
  .comm-card__period { display: inline-block; margin-bottom: 12px; padding: 4px 12px; border-radius: 999px; background: var(--accent-soft); color: var(--accent); font-size: 13px; font-weight: 700; }
  .comm-card h3 { font-size: 19px; letter-spacing: -0.01em; }
  .comm-card p { margin-top: 8px; color: var(--text-muted); }
  @media (max-width: 780px) { .communities { grid-template-columns: 1fr; } }
</style>
