---
import { skills } from '../../data/content';
import { ui, t } from '../../i18n/ui';
import type { Locale } from '../../data/content';
interface Props { locale: Locale; }
const { locale } = Astro.props;
---
<section class="section section--tight" id="skills">
  <div class="container">
    <div class="reveal">
      <span class="eyebrow">{t(ui.sections.skills, locale)}</span>
      <h2 class="section-title">{locale === 'ru' ? 'Навыки и инструменты' : 'Skills & tools'}</h2>
    </div>

    <div class="skills">
      {skills.map((group) => (
        <div class="skills__group reveal">
          <h3 class="skills__title">{t(group.title, locale)}</h3>
          <div class="skills__items">
            {group.items.filter((s) => !(locale === 'en' && s === 'Яндекс.Метрика')).map((s) => <span class="tag">{s}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills { margin-top: 44px; display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; align-items: start; }
  .skills__group { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 28px; }
  .skills__group:first-child { grid-column: 1 / -1; }
  .skills__title { font-size: 17px; margin-bottom: 18px; padding-bottom: 14px; border-bottom: 1px solid var(--border); }
  .skills__items { display: flex; flex-wrap: wrap; gap: 8px; }
  .skills__group .tag { background: var(--bg); }
  @media (max-width: 900px) { .skills { grid-template-columns: 1fr; } }
</style>
