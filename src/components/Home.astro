---
import Hero from './sections/Hero.astro';
import Companies from './sections/Companies.astro';
import About from './sections/About.astro';
import Services from './sections/Services.astro';
import Experience from './sections/Experience.astro';
import Testimonials from './sections/Testimonials.astro';
import Skills from './sections/Skills.astro';
import Portfolio from './sections/Portfolio.astro';
import Communities from './sections/Communities.astro';
import Media from './sections/Media.astro';
import Certificates from './sections/Certificates.astro';
import Gallery from './sections/Gallery.astro';
import Contact from './sections/Contact.astro';
import type { Locale } from '../data/content';
interface Props { locale: Locale; }
const { locale } = Astro.props;
---
<Hero locale={locale} />
<Companies locale={locale} />
<About locale={locale} />
{import.meta.env.DEV && <Services locale={locale} />}
<Experience locale={locale} />
{import.meta.env.DEV && <Testimonials locale={locale} />}
<Skills locale={locale} />
<Portfolio locale={locale} />
<Communities locale={locale} />
<Media locale={locale} />
<Certificates locale={locale} />
<Gallery locale={locale} />
<Contact locale={locale} />
