---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { profile, contacts } from '../data/content';
import type { Locale } from '../data/content';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  path: string;
}
const { title, description, locale, path } = Astro.props;
const SITE = Astro.site ?? new URL('https://www.arturmarkarian.com');
const basePath = path.replace(/^\/en/, '') || '/';
const canonical = new URL(path, SITE).toString();
const ogImage = new URL('/og.png', SITE).toString();
const ruHref = new URL(basePath, SITE).toString();
const enHref = new URL('/en' + (basePath === '/' ? '' : basePath), SITE).toString();
const ogLocale = locale === 'ru' ? 'ru_RU' : 'en_US';
const ogLocaleAlt = locale === 'ru' ? 'en_US' : 'ru_RU';
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.name[locale],
  alternateName: locale === 'ru' ? profile.name.en : profile.name.ru,
  jobTitle: profile.role[locale],
  url: SITE.toString(),
  image: new URL('/portrait.jpg', SITE).toString(),
  email: 'mailto:' + contacts.email,
  sameAs: [contacts.linkedin, contacts.telegram.url, contacts.getmentor],
  knowsLanguage: ['ru', 'en'],
};
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="17BjN4PRcs6zQqrXWM5mUQV33tS1bqnZda3JsxpTCOM" />
    <meta name="yandex-verification" content="524b31df8b7fba41" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="ru" href={ruHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={ruHref} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Artur Markarian" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${profile.name[locale]} — ${profile.role[locale]}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(personLd)} is:inline />
    <meta name="author" content="Artur Markarian" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Yandex.Metrika counter -->
    <script is:inline>
      (function (m, e, t, r, i, k, a) {
        m[i] = m[i] || function () { (m[i].a = m[i].a || []).push(arguments); };
        m[i].l = 1 * new Date();
        for (var j = 0; j < e.scripts.length; j++) { if (e.scripts[j].src === r) { return; } }
        k = e.createElement(t), a = e.getElementsByTagName(t)[0], k.async = 1, k.src = r, a.parentNode.insertBefore(k, a);
      })(window, document, 'script', 'https://mc.yandex.ru/metrika/tag.js', 'ym');
      ym(110397461, 'init', { clickmap: true, trackLinks: true, accurateTrackBounce: true, webvisor: true });
    </script>
    <noscript><div><img src="https://mc.yandex.ru/watch/110397461" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
    <!-- /Yandex.Metrika counter -->

    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
        } catch (e) {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>

    <script is:inline>
      (function () {
        if (location.pathname !== '/') return;
        var pref = null;
        try { pref = localStorage.getItem('lang'); } catch (e) {}
        if (pref !== 'ru' && pref !== 'en') {
          var primary = (navigator.languages && navigator.languages[0]) || navigator.language || 'en';
          pref = primary.toLowerCase().indexOf('ru') === 0 ? 'ru' : 'en';
        }
        if (pref === 'en') {
          location.replace('/en' + location.search + location.hash);
        }
      })();
    </script>
  </head>
  <body>
    <Header locale={locale} path={path} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />

    <div class="cookie-notice" id="cookie-notice" hidden>
      <p>
        {locale === 'ru'
          ? 'Сайт использует файлы cookie и Яндекс.Метрику (включая запись действий) для аналитики и улучшения работы. Продолжая пользоваться сайтом, вы соглашаетесь с этим.'
          : 'This site uses cookies and Yandex.Metrica (including interaction recording) for analytics and improvement. By continuing to use the site, you agree to this.'}
      </p>
      <button type="button" id="cookie-accept" class="btn btn--primary">{locale === 'ru' ? 'Хорошо' : 'Got it'}</button>
    </div>

    <script>
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 },
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      document.querySelectorAll('.show-more').forEach((btn) => {
        const grid = document.getElementById(btn.dataset.grid);
        if (!grid) return;
        btn.addEventListener('click', () => {
          const collapsed = grid.classList.toggle('is-collapsed');
          btn.textContent = collapsed ? btn.dataset.more : btn.dataset.less;
        });
      });

      (function () {
        const notice = document.getElementById('cookie-notice');
        if (!notice) return;
        let agreed = false;
        try { agreed = localStorage.getItem('cookie-consent') === '1'; } catch (e) {}
        if (!agreed) notice.hidden = false;
        document.getElementById('cookie-accept')?.addEventListener('click', () => {
          try { localStorage.setItem('cookie-consent', '1'); } catch (e) {}
          notice.hidden = true;
        });
      })();
    </script>
  </body>
</html>
